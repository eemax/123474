---
import Base from "../layouts/Base.astro";
---

<Base title="404 — Not Found">
  <section class="flex flex-col items-center justify-center py-24 text-center">
    <h1 class="font-mono text-6xl font-bold tracking-tighter">404</h1>
    <p class="mt-4 text-lg text-(--muted)">Page not found.</p>
    <a
      href="/"
      class="mt-8 rounded-full border border-(--border) px-5 py-2 text-sm no-underline transition-colors hover:bg-(--surface)"
    >
      Back to home
    </a>
  </section>
</Base>
