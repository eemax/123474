---
interface Props {
  headings: { depth: number; slug: string; text: string }[];
}

const { headings } = Astro.props;
const filtered = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{filtered.length > 0 && (
  <nav class="mb-10 rounded-lg border border-(--border) p-5">
    <p class="mb-3 font-mono text-xs font-semibold uppercase tracking-wider text-(--muted)">
      On this page
    </p>
    <ul class="space-y-1.5 text-sm">
      {filtered.map((heading) => (
        <li style={heading.depth === 3 ? "padding-left: 1rem;" : ""}>
          <a
            href={`#${heading.slug}`}
            class="text-(--muted) no-underline transition-colors hover:text-(--fg)"
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ul>
  </nav>
)}
