---
const year = new Date().getFullYear();
---

<footer data-pagefind-ignore class="border-t border-(--border) py-10">
  <div class="mx-auto flex max-w-3xl flex-col items-center gap-4 px-6 text-sm text-(--muted)">
    <div class="flex gap-6">
      <a href="https://github.com" target="_blank" rel="noopener noreferrer" class="transition-colors hover:text-(--fg)">
        GitHub
      </a>
      <a href="/rss.xml" class="transition-colors hover:text-(--fg)">
        RSS
      </a>
    </div>
    <p>&copy; {year} 123474.xyz</p>
  </div>
</footer>
