---
interface Props {
  title: string;
  description: string;
  date: Date;
  tags: string[];
  slug: string;
}

const { title, description, date, tags, slug } = Astro.props;

const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "short",
  day: "numeric",
});
---

<article class="group">
  <a href={`/blog/${slug}`} class="block no-underline">
    <div class="rounded-lg border border-(--border) p-5 transition-colors hover:bg-(--surface)">
      <div class="flex items-baseline justify-between gap-4">
        <h3 class="font-semibold tracking-tight group-hover:underline group-hover:underline-offset-4">
          {title}
        </h3>
        <time datetime={date.toISOString()} class="shrink-0 text-sm text-(--muted)">
          {formattedDate}
        </time>
      </div>
      <p class="mt-2 text-sm text-(--muted) line-clamp-2">{description}</p>
      {tags.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-1.5">
          {tags.map((tag) => (
            <span class="rounded-full border border-(--border) px-2 py-0.5 font-mono text-xs text-(--muted)">
              {tag}
            </span>
          ))}
        </div>
      )}
    </div>
  </a>
</article>
