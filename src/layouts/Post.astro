---
import Base from "./Base.astro";
import Prose from "../components/Prose.astro";
import TableOfContents from "../components/TableOfContents.astro";
import ReadingProgress from "../components/svelte/ReadingProgress.svelte";
import type { CollectionEntry } from "astro:content";

interface Props {
  post: CollectionEntry<"blog">;
  headings: { depth: number; slug: string; text: string }[];
  prevPost?: { slug: string; title: string } | null;
  nextPost?: { slug: string; title: string } | null;
  readingTime?: number;
}

const { post, headings, prevPost, nextPost, readingTime } = Astro.props;
const { title, description, date, updated, tags, cover, coverAlt } = post.data;

const formattedDate = date.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const formattedUpdated = updated?.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});
---

<Base title={title} description={description} image={cover} jsonLd={{
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  description,
  datePublished: date.toISOString(),
  ...(updated && { dateModified: updated.toISOString() }),
  url: Astro.url.href,
  ...(cover && { image: new URL(cover, Astro.site).href }),
  author: { "@type": "Person", name: "123474", url: Astro.site?.href },
}}>
  <ReadingProgress client:visible />

  <article>
    <header class="mb-10">
      <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">{title}</h1>
      <div class="mt-3 flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-(--muted)">
        <time datetime={date.toISOString()}>{formattedDate}</time>
        {readingTime && <span>{readingTime} min read</span>}
        {formattedUpdated && <span>Updated {formattedUpdated}</span>}
      </div>
      {tags.length > 0 && (
        <div class="mt-3 flex flex-wrap gap-2">
          {tags.map((tag) => (
            <a
              href={`/tags/${tag}`}
              class="rounded-full border border-(--border) px-3 py-0.5 font-mono text-xs text-(--muted) no-underline transition-colors hover:bg-(--surface) hover:text-(--fg)"
            >
              {tag}
            </a>
          ))}
        </div>
      )}
    </header>

    {cover && (
      <img
        src={cover}
        alt={coverAlt || ""}
        class="mb-10 w-full rounded-lg"
      />
    )}

    {headings.length > 0 && <TableOfContents headings={headings} />}

    <Prose>
      <slot />
    </Prose>
  </article>

  <!-- Prev / Next navigation -->
  <nav class="mt-16 flex items-stretch gap-4 border-t border-(--border) pt-8 text-sm">
    {prevPost ? (
      <a href={`/blog/${prevPost.slug}`} class="flex-1 no-underline">
        <span class="text-(--muted)">&larr; Previous</span>
        <span class="mt-1 block font-medium">{prevPost.title}</span>
      </a>
    ) : <div class="flex-1" />}
    {nextPost ? (
      <a href={`/blog/${nextPost.slug}`} class="flex-1 text-right no-underline">
        <span class="text-(--muted)">Next &rarr;</span>
        <span class="mt-1 block font-medium">{nextPost.title}</span>
      </a>
    ) : <div class="flex-1" />}
  </nav>
</Base>
